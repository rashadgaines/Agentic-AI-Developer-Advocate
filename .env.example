# Notion Product Feedback Database ID
# Create database "RC Dev — Product Feedback" and share with your integration
NOTION_FEEDBACK_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Operator Identity (for audit logs)
